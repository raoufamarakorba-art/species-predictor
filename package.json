{
  "name": "species-predictor",
  "version": "0.3.0",
  "description": "Species occurrence explorer using iNaturalist data and ChatGPT-ready exports",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --app-dir server",
    "dev:server:reload": "python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000 --app-dir server",
    "test": "npm run test:server && npm run test:client",
    "test:server": "python -m pytest server/tests",
    "test:client": "npm run test --prefix client",
    "build": "cd client && npm run build",
    "start": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --app-dir server",
    "install:all": "npm install && cd client && npm install && cd .. && python -m pip install -r server/requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
