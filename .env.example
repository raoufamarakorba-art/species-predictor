# ── Species Predictor – configuration locale ──────────────────────────────────
# Copiez ce fichier en .env. Ne commitez JAMAIS .env sur git !

# Port du serveur FastAPI (défaut 8000)
PORT=8000

# Origine autorisée pour CORS
ALLOWED_ORIGIN=http://localhost:5173

# Cache iNaturalist côté backend, en secondes
INATURALIST_CACHE_TTL_SECONDS=300

# Stockage permanent local
# Par défaut: ./data/species_predictor.sqlite3
# SPECIES_DATA_DIR=data
# SPECIES_DATABASE_PATH=data/species_predictor.sqlite3

NODE_ENV=development
