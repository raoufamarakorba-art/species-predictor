# ── Species Predictor – configuration Ollama ──────────────────────────────────
# Copiez ce fichier en .env. Ne commitez JAMAIS .env sur git !

# URL d'Ollama (défaut : local)
OLLAMA_URL=http://localhost:11434

# Modèle à utiliser. Recommandés :
#   mistral       – rapide, bon en français   (4.1 GB)
#   llama3.2      – très bon équilibre        (2 GB)
#   llama3.1:8b   – plus puissant             (4.7 GB)
#   gemma3:4b     – léger et efficace         (3.3 GB)
OLLAMA_MODEL=mistral

# Port du serveur FastAPI (défaut 8000)
PORT=8000

# Origine autorisée pour CORS
ALLOWED_ORIGIN=http://localhost:5173

# Cache iNaturalist côté backend, en secondes
INATURALIST_CACHE_TTL_SECONDS=300

NODE_ENV=development
